            },
            {
              "key": "de",
              "label": "Deutsch"
            },
            {
              "key": "fr",
              "label": "Français"
            },
            {
              "key": "vi",
              "label": "Tiếng Việt"
            }
          ],
          "desc": "仅在“歌词翻译”打开时生效。"
        }
      ],
      "boxjs": {
        "hosts": [
          "youtubei.googleapis.com",
          "www.youtube.com",
          "s.youtube.com",
          "*.googlevideo.com"
        ],
        "schema": {
          "YouTubeEnhance.tabs": {
            "type": "textarea",
            "label": "底部栏目",
            "default": "home,subscriptions,history,you",
