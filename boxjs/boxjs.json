  "repo": "https://github.com/yjlsx/qx",
  "apps": [
    {
      "id": "youtube_enhance",
      "name": "YouTube增强版",
      "author": "@yjlsx",
      "repo": "https://github.com/yjlsx/qx",
      "icons": [
        "https://yjlsx.github.io/features-plugin/icons/youtube.png"
      ],
      "script": "https://raw.githubusercontent.com/yjlsx/qx/refs/heads/main/rewrite/youtube.response.js",
      "keys": [
        "YouTubeEnhance.tabs",
        "YouTubeEnhance.showHistory",
        "YouTubeEnhance.debug",
        "YouTubeEnhance.noAds",
        "YouTubeEnhance.backgroundPlayback",
        "YouTubeEnhance.pictureInPicture",
        "YouTubeEnhance.blockShorts",
        "YouTubeEnhance.hideShorts",
        "YouTubeEnhance.removeShorts",
        "YouTubeEnhance.removeSubscriptions",
        "YouTubeEnhance.removeUploads",
        "YouTubeEnhance.removeLibrary",
        "YouTubeEnhance.blockImmersive",
        "YouTubeEnhance.noPromotionCards",
        "YouTubeEnhance.noRelatedWatchNexts",
        "YouTubeEnhance.captionTranslate",
        "YouTubeEnhance.captionTargetLang",
        "YouTubeEnhance.captionLang",
        "YouTubeEnhance.lyricTranslate",
        "YouTubeEnhance.lyricTargetLang",
        "YouTubeEnhance.lyricLang"
      ],
      "settings": [
        {
          "id": "YouTubeEnhance.tabs",
          "name": "底部栏目",
          "val": "home,subscriptions,history,you",
          "type": "textarea",
          "desc": "英文逗号分隔。支持 home, shorts, subscriptions, history, you, uploads。隐藏某栏时也建议从这里移除对应名称。"
        },
        {
          "id": "YouTubeEnhance.showHistory",
          "name": "显示历史入口",
          "val": true,
          "type": "boolean",
          "desc": "在底部栏目/Guide 中加入历史入口。"
        },
        {
          "id": "YouTubeEnhance.debug",
          "name": "调试日志",
          "val": false,
          "type": "boolean",
          "desc": "打开后可在 Quantumult X 日志里查看脚本处理过程。"
        },
        {
          "id": "YouTubeEnhance.removeLibrary",
          "name": "隐藏我的栏目",
          "val": false,
          "type": "boolean",
          "desc": "隐藏“我/You/Library”底栏。"
        },
        {
          "id": "YouTubeEnhance.removeShorts",
          "name": "隐藏 Shorts 栏目",
          "val": true,
          "type": "boolean",
          "desc": "隐藏底部 Shorts 栏目。"
        },
        {
          "id": "YouTubeEnhance.removeSubscriptions",
          "name": "隐藏订阅栏目",
          "val": false,
          "type": "boolean",
          "desc": "隐藏底部订阅栏目。"
        },
        {
          "id": "YouTubeEnhance.removeUploads",
          "name": "隐藏上传入口",
          "val": true,
          "type": "boolean",
          "desc": "隐藏上传/创建入口。"
        },
        {
          "id": "YouTubeEnhance.noAds",
          "name": "移除广告",
          "val": true,
          "type": "boolean",
          "desc": "过滤广告和推广响应。"
        },
        {
          "id": "YouTubeEnhance.backgroundPlayback",
          "name": "后台播放",
          "val": true,
          "type": "boolean",
          "desc": "注入后台播放能力。"
        },
        {
          "id": "YouTubeEnhance.pictureInPicture",
          "name": "画中画",
          "val": true,
          "type": "boolean",
          "desc": "注入 PiP 能力。"
        },
        {
          "id": "YouTubeEnhance.blockShorts",
          "name": "屏蔽 Shorts 内容",
          "val": true,
          "type": "boolean",
          "desc": "过滤首页、搜索、推荐中的 Shorts 内容。"
        },
        {
          "id": "YouTubeEnhance.hideShorts",
          "name": "隐藏 Shorts 响应",
          "val": true,
          "type": "boolean",
          "desc": "兼容旧脚本参数。"
        },
        {
          "id": "YouTubeEnhance.blockImmersive",
          "name": "隐藏沉浸式音乐入口",
          "val": false,
          "type": "boolean",
          "desc": "过滤 FEmusic_immersive。"
        },
        {
          "id": "YouTubeEnhance.noPromotionCards",
          "name": "隐藏推广卡片",
          "val": true,
          "type": "boolean",
          "desc": "过滤赞助、推广卡片。"
        },
        {
          "id": "YouTubeEnhance.noRelatedWatchNexts",
          "name": "减少播放页推荐",
          "val": false,
          "type": "boolean",
          "desc": "尽量过滤播放页推荐。"
        },
        {
          "id": "YouTubeEnhance.captionTranslate",
          "name": "字幕翻译",
          "val": false,
          "type": "boolean",
          "desc": "打开后按下方选择的语言注入字幕翻译。"
        },
        {
          "id": "YouTubeEnhance.captionTargetLang",
          "name": "字幕目标语言",
          "val": "zh-Hans",
          "type": "radios",
          "items": [
            {
              "key": "zh-Hans",
              "label": "简体中文"
            },
            {
              "key": "zh-Hant",
              "label": "繁体中文"
            },
            {
              "key": "en",
              "label": "English"
            },
            {
