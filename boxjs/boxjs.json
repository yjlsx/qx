            "rows": 4,
            "placeholder": "P00001=xxx; P00003=xxx; __dfp=xxx;"
          },
          "iQIYI_LogDetails": {
            "type": "boolean",
            "label": "调试日志",
            "default": false,
            "desc": "开启后输出接口响应详情。"
          },
          "iQIYI_ShakeLottery": {
            "type": "boolean",
            "label": "摇一摇限免3次",
            "default": false,
            "desc": "开启后会先查询今日免费次数；次数为0时跳过，避免消耗积分。"
          }
        }
      }
    }
