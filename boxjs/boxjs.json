            },
            {
              "key": "vi",
              "label": "Tiếng Việt"
            }
          ],
          "desc": "仅在“字幕翻译”打开时生效。"
        },
        {
          "id": "YouTubeEnhance.lyricTranslate",
          "name": "歌词翻译",
          "val": false,
          "type": "boolean",
          "desc": "打开后按下方选择的语言翻译音乐歌词。"
        },
        {
          "id": "YouTubeEnhance.lyricTargetLang",
          "name": "歌词目标语言",
          "val": "zh-Hans",
