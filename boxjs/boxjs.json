    {
      "id": "kuaishou",
      "name": "快手签到",
      "author": "@yjlsx",
      "repo": "https://github.com/yjlsx/qx",
      "icons": [
        "https://raw.githubusercontent.com/yjlsx/qx/refs/heads/main/icon/kuaishou.png"
      ],
      "script": "https://raw.githubusercontent.com/yjlsx/qx/refs/heads/main/task/kuaishou.js",
      "keys": [
        "ks_enabled_1",
        "ks_cookie_1",
        "ks_enabled_2",
        "ks_cookie_2",
        "ks_watch_ad_enabled",
        "ks_cookie_target"
      ],
      "settings": [
        {
          "id": "ks_enabled_1",
          "name": "启用账号1",
          "val": true,
          "type": "boolean",
          "desc": "控制是否启用快手账号1。"
        },
        {
          "id": "ks_cookie_1",
          "name": "账号1 Cookie",
          "val": "",
          "type": "textarea",
          "desc": "用于快手签到，支持自动捕获或手动填写。"
        },
        {
          "id": "ks_enabled_2",
          "name": "启用账号2",
          "val": true,
          "type": "boolean",
          "desc": "控制是否启用快手账号2。"
        },
        {
          "id": "ks_cookie_2",
          "name": "账号2 Cookie",
          "val": "",
          "type": "textarea",
          "desc": "用于快手签到，支持自动捕获或手动填写。"
        },
        {
          "id": "ks_watch_ad_enabled",
          "name": "看广告领金币",
          "val": false,
          "type": "boolean",
          "desc": "开启后执行广告领奖接口，接口不稳定时可关闭。"
        },
        {
          "id": "ks_cookie_target",
          "name": "Cookie写入账号",
          "val": "0",
          "type": "radios",
          "items": [
            {
              "key": "0",
              "label": "自动"
            },
            {
              "key": "1",
              "label": "账号1"
            },
            {
              "key": "2",
              "label": "账号2"
            }
          ],
          "desc": "自动捕获 Cookie 时写入的账号槽位。"
        }
      ],
      "boxjs": {
        "hosts": [
          "kuaishou.com",
          "*.kuaishou.com"
        ],
        "schema": {
          "ks_enabled_1": {
            "type": "boolean",
            "label": "启用账号1",
            "default": true,
            "desc": "控制是否启用快手账号1。"
          },
          "ks_cookie_1": {
            "type": "textarea",
            "label": "账号1 Cookie",
            "default": "",
            "desc": "用于快手签到，支持自动捕获或手动填写。",
            "rows": 3,
            "input": "password"
          },
          "ks_enabled_2": {
            "type": "boolean",
            "label": "启用账号2",
            "default": true,
            "desc": "控制是否启用快手账号2。"
          },
          "ks_cookie_2": {
            "type": "textarea",
            "label": "账号2 Cookie",
            "default": "",
            "desc": "用于快手签到，支持自动捕获或手动填写。",
            "rows": 3,
            "input": "password"
          },
          "ks_watch_ad_enabled": {
            "type": "boolean",
            "label": "看广告领金币",
            "default": false,
            "desc": "开启后执行广告领奖接口，接口不稳定时可关闭。"
          },
          "ks_cookie_target": {
            "type": "radios",
            "label": "Cookie写入账号",
            "default": "0",
            "items": [
              {
                "key": "0",
                "label": "自动"
              },
              {
                "key": "1",
                "label": "账号1"
              },
              {
                "key": "2",
                "label": "账号2"
              }
            ],
            "desc": "自动捕获 Cookie 时写入的账号槽位。"
          }
        }
      }
    },
    {
      "id": "lixianla",
      "name": "离线啦签到",
      "author": "@yjlsx",
      "repo": "https://github.com/yjlsx/qx",
      "icons": [
        "https://raw.githubusercontent.com/yjlsx/qx/refs/heads/main/icon/qwe.png"
      ],
      "script": "https://raw.githubusercontent.com/yjlsx/qx/refs/heads/main/task/lixianla.js",
      "keys": [
        "lixianla_cookie",
        "lixianla_ocr_key"
      ],
      "settings": [
        {
          "id": "lixianla_cookie",
          "name": "离线啦 Cookie",
          "val": "",
          "type": "textarea",
          "desc": "开启重写后访问 lixianla.com 自动写入，也可手动填写包含 bbs_token、bbs_sid 的 Cookie。"
        },
        {
          "id": "lixianla_ocr_key",
          "name": "OCR Space API Key",
          "val": "",
          "type": "text",
          "desc": "填写 ocr.space 的 apikey，用于自动识别签到验证码。"
        }
      ],
      "boxjs": {
        "hosts": [
          "lixianla.com"
        ],
        "schema": {
          "lixianla_cookie": {
            "type": "textarea",
            "label": "离线啦 Cookie",
            "default": "",
            "desc": "开启重写后访问 lixianla.com 自动写入，也可手动填写包含 bbs_token、bbs_sid 的 Cookie。",
            "rows": 4,
            "placeholder": "bbs_token=xxx; bbs_sid=xxx;"
          },
          "lixianla_ocr_key": {
            "type": "text",
            "label": "OCR Space API Key",
            "default": "",
            "desc": "填写 ocr.space 的 apikey，用于自动识别签到验证码。",
            "input": "password",
            "placeholder": "Kxxxxxxxxxxxx"
          }
        }
      }
    },
    {
      "id": "iqiyi_daily_bonus",
      "name": "爱奇艺签到",
      "author": "@NobyDa",
      "repo": "https://github.com/yjlsx/qx",
      "icons": [
        "https://raw.githubusercontent.com/yjlsx/qx/refs/heads/main/icon/qwe.png"
      ],
      "script": "https://raw.githubusercontent.com/yjlsx/qx/refs/heads/main/task/iQIYI.js",
      "keys": [
        "CookieQY",
        "iQIYI_LogDetails",
        "iQIYI_ShakeLottery"
      ],
      "settings": [
        {
          "id": "CookieQY",
          "name": "爱奇艺 Cookie",
          "val": "",
          "type": "textarea",
          "desc": "Safari 打开 https://m.iqiyi.com/user.html 登录后自动捕获，或手动填写包含 P00001、P00003、__dfp 的 Cookie。"
        },
        {
          "id": "iQIYI_LogDetails",
          "name": "调试日志",
          "val": false,
          "type": "boolean",
          "desc": "开启后在日志中输出接口响应详情。"
        },
        {
          "id": "iQIYI_ShakeLottery",
          "name": "摇一摇限免3次",
          "val": false,
          "type": "boolean",
          "desc": "开启后会先查询今日免费次数；次数为0时跳过，避免消耗积分。"
        }
      ],
      "boxjs": {
        "hosts": [
          "passport.iqiyi.com"
        ],
        "schema": {
          "CookieQY": {
            "type": "textarea",
            "label": "爱奇艺 Cookie",
            "default": "",
